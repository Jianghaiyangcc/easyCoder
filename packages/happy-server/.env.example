# Copy this file to .env.dev for local development.

# ============================================
# Required - standalone (pnpm standalone:dev)
# ============================================
DB_PROVIDER=pglite
HANDY_MASTER_SECRET=change-me-local-secret
PORT=3005
NODE_ENV=development

# ============================================
# Optional - standalone defaults
# ============================================
PUBLIC_URL=http://localhost:3005
DATA_DIR=./data
PGLITE_DIR=./data/pglite

# Metrics server
METRICS_ENABLED=true
METRICS_PORT=9090

# Centralized logging for AI debugging (creates .logs directory)
DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=false

# ============================================
# Full deployment only (NOT needed for standalone)
# Uncomment and set DB_PROVIDER=postgres to use
# ============================================

# DB_PROVIDER=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/handy

# Redis (cross-process pub/sub)
# REDIS_URL=redis://localhost:6379

# S3/MinIO - file storage (start with `pnpm s3`)
# S3_HOST=localhost
# S3_PORT=9000
# S3_USE_SSL=false
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=happy
# S3_PUBLIC_URL=http://localhost:9000/happy

# Voice - 11Labs API key (secret, not checked in)
# ELEVENLABS_API_KEY=

# Voice - DashScope/Bailian
# DASHSCOPE_API_KEY=
# DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_ASR_MODEL=qwen3-asr-flash
# DASHSCOPE_TTS_MODEL=qwen3-tts-flash
# DASHSCOPE_TTS_VOICE=Cherry

# Voice webhook secret (shared between ElevenLabs webhook config and this server)
# VOICE_WEBHOOK_SECRET=

# Local scripting - set ELEVENLABS_ANALYTICS_KEY in your shell env for scripts/voice-usage.py
# ELEVENLABS_ANALYTICS_KEY=
