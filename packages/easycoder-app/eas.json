{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "ENABLE_ANDROID_GOOGLE_SERVICES": "false",
        "EXPO_PUBLIC_REMOTE_PUSH_ENABLED": "false"
      }
    },
    "development-store": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "ENABLE_ANDROID_GOOGLE_SERVICES": "false",
        "EXPO_PUBLIC_REMOTE_PUSH_ENABLED": "false"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "ENABLE_ANDROID_GOOGLE_SERVICES": "false",
        "EXPO_PUBLIC_REMOTE_PUSH_ENABLED": "false"
      }
    },
    "preview-store": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "ENABLE_ANDROID_GOOGLE_SERVICES": "false",
        "EXPO_PUBLIC_REMOTE_PUSH_ENABLED": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1",
        "ENABLE_ANDROID_GOOGLE_SERVICES": "false",
        "EXPO_PUBLIC_REMOTE_PUSH_ENABLED": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "80208977@qq.com",
        "ascAppId": "6764458834",
        "appleTeamId": "24ALGS8D5N"
      }
    }
  }
}
